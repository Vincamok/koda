{
  "db_name": "PostgreSQL",
  "query": "SELECT t.id, t.organization_id, t.name, t.description, t.created_at,\n                  COUNT(tm.id) AS member_count\n           FROM teams t\n           LEFT JOIN team_memberships tm ON tm.team_id = t.id\n           WHERE t.organization_id = $1\n           GROUP BY t.id\n           ORDER BY t.name\n           LIMIT $2 OFFSET $3",
