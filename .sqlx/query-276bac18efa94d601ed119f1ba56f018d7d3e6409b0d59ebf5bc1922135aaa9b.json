  "query": "SELECT tm.id, tm.team_id, tm.user_id, tm.role, tm.created_at,\n                  u.email, u.display_name\n           FROM team_memberships tm\n           JOIN users u ON u.id = tm.user_id\n           WHERE tm.team_id = $1\n           ORDER BY tm.role, u.email",
