{
  "db_name": "PostgreSQL",
  "query": "SELECT u.id, u.email, u.display_name, u.is_super_admin, u.email_verified, u.created_at,\n                  COUNT(m.organization_id) AS org_count\n           FROM users u\n           LEFT JOIN memberships m ON m.user_id = u.id\n           WHERE ($1::TEXT IS NULL OR u.email ILIKE '%' || $1 || '%')\n           GROUP BY u.id\n           ORDER BY u.created_at DESC\n           LIMIT $2 OFFSET $3",
