# URL de connexion Redis (obligatoire si différente de la valeur par défaut)
REDIS_URL=redis://localhost:6379

# URL de connexion PostgreSQL (obligatoire — base de données Koda)
DATABASE_URL=postgres://koda:password@localhost:5432/koda

# Identifiant de ce worker dans le consumer group Redis
# Doit être unique par instance déployée
WORKER_ID=mcp-gateway-1

# Nombre de tentatives avant de déplacer un job dans jobs:dead_letter
DEAD_LETTER_MAX_ATTEMPTS=3
